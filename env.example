# Moovimiento - Environment variables (copy to .env.local for development)

# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Branding and domain
NEXT_PUBLIC_BASE_URL=https://moovimiento.com
NEXT_PUBLIC_BRAND_NAME=Moovimiento

# Mercado Pago
MERCADOPAGO_ACCESS_TOKEN=
MERCADOPAGO_WEBHOOK_SECRET=

# Bank transfer (optional)
TRANSFER_ALIAS=
TRANSFER_CBU=

# Email service (optional)
RESEND_API_KEY=

# Coupons
# Validated server-side via Supabase `coupons` table.
